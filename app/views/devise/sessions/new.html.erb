<div class="w-full max-w-md">
  <div class="bg-white rounded-2xl shadow-sm ring-1 ring-gray-200 px-8 py-8">
    <h1 class="text-xl font-semibold text-center text-gray-900 mb-6">Welcome back</h1>

    <% if resource.errors.any? %>
      <div class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">
        <ul class="list-disc pl-5 space-y-1">
          <% resource.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="<%= "#{resource_name}_email" %>">Email</label>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
                          class: "block w-full rounded-lg border-0 bg-indigo-50 px-3 py-2.5 text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="<%= "#{resource_name}_password" %>">Password</label>
        <%= f.password_field :password, autocomplete: "current-password",
                             class: "block w-full rounded-lg border-0 bg-indigo-50 px-3 py-2.5 text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <label class="inline-flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-gray-300 text-indigo-500 focus:ring-indigo-500" %>
          Remember me
        </label>
      <% end %>

      <%= f.submit "Log in",
                   class: "w-full rounded-lg bg-indigo-500 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-600 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 cursor-pointer" %>
    <% end %>

    <div class="mt-6 border-t pt-4 flex justify-center gap-5 text-sm">
      <%= link_to "Sign up", new_registration_path(resource_name), class: "text-indigo-500 hover:text-indigo-600" %>
      <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-indigo-500 hover:text-indigo-600" %>
    </div>
  </div>
</div>
